PROJECT_NAME=Asset Manager
API_V1_PREFIX=/api/v1
SECRET_KEY=replace-with-at-least-32-char-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_ALGORITHM=HS256
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

MARIADB_DATABASE=asset_manager
MARIADB_USER=asset_user
MARIADB_PASSWORD=asset_password
MARIADB_ROOT_PASSWORD=root_password
MARIADB_HOST=db
MARIADB_PORT=3306

DATABASE_URL=mysql+pymysql://asset_user:asset_password@db:3306/asset_manager
DOCUMENT_STORAGE_PATH=/app/storage/documents
NOTIFICATION_EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Asset Manager
SMTP_USE_STARTTLS=true
SMTP_USE_SSL=false
NOTIFICATION_DEFAULT_RECIPIENTS=

VITE_API_BASE_URL=http://localhost:8000/api/v1
